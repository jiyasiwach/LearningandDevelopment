# Supabase — browser-safe keys are exposed via NEXT_PUBLIC_*.
# Leave unset to run the portal in demo/placeholder mode (no real backend).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — required for scripts/ingest-training-doc.ts (vector-search
# ingestion of the AI Bot Training Document). Leave unset and the AI
# Assistant still works via keyword/phrase retrieval over the same content —
# see src/lib/training-search.ts. See README "AI Assistant" section.
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=

# OpenRouter — powers the AI Assistant's answer-synthesis step
# (/api/assistant/chat). Retrieval finds the right training-doc chunks
# locally; the LLM turns them into a natural answer. If unset or the call
# fails, the assistant falls back to returning the raw chunk text.
OPENROUTER_API_KEY=
